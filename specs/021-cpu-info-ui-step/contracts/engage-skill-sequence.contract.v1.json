{
  "skill": "engage-red-hat-support",
  "routingPolicy": {
    "primaryMode": "ui_first",
    "compatibilityEntryUri": "ui://engage-red-hat-support/app.html",
    "textFallbackRequired": true
  },
  "requiredSequence": [
    {
      "step": 1,
      "name": "select_product",
      "requiredCalls": ["start_engage_red_hat_support", "select_engage_product"],
      "requiredOutputKeys": ["selected_product"]
    },
    {
      "step": 2,
      "name": "troubleshooting_cpu_review",
      "requiredCalls": ["get_cpu_information"],
      "requiredOutputKeys": [
        "model",
        "logical_cores",
        "physical_cores",
        "frequency_mhz",
        "load_avg_1m",
        "load_avg_5m",
        "load_avg_15m",
        "cpu_line"
      ]
    },
    {
      "step": 3,
      "name": "consent_generate_fetch_sos",
      "requiredCalls": ["mint_engage_consent_token", "generate_sosreport", "fetch_sosreport"],
      "requiredOutputKeys": ["consent_token", "fetch_reference", "artifact_ref"]
    },
    {
      "step": 4,
      "name": "connect_verify_attach",
      "requiredCalls": ["jira_connect_secure", "jira_connection_status", "jira_list_attachments", "jira_attach_artifact"],
      "requiredOutputKeys": ["connection_id", "issue_access_verified"]
    }
  ],
  "deterministicFallbackKeys": [
    "workflow_session_id",
    "consent_token",
    "expires_at",
    "job_id",
    "status",
    "fetch_reference",
    "connection_id"
  ],
  "securityBoundary": {
    "explicitPermissionRequiredBeforeGenerate": true,
    "forbiddenInputFields": ["pat", "api_token", "token"],
    "opaqueReference": "connection_id"
  }
}
